# PostgreSQL (Neon) - Main DB for Router Configuration
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# SQL Server Configuration (Example for dynamic connection)
# These will be stored in the database, but you can keep defaults here
SQL_SERVER_HOST=
SQL_SERVER_PORT=1433
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
SQL_SERVER_DATABASE=

# Security
JWT_SECRET=your_jwt_secret_here
API_KEY_HEADER=x-api-key
