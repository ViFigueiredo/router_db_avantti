# API Configuration
API_URL=http://localhost:8000

# SQLite Configuration (Used by Python)
# The database file will be created in the backend folder
SQLITE_DB_PATH=sql_router.db

# SQL Server Configuration (Example for dynamic connection)
# These will be stored in the database per project, but you can keep defaults here
SQL_SERVER_HOST=
SQL_SERVER_PORT=1433
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
SQL_SERVER_DATABASE=

# Security
API_KEY_HEADER=x-api-key
