# API Configuration
API_URL=http://localhost:8000

# SQLite Configuration (Used by Python)
# The database file will be created in the backend folder
SQLITE_DB_PATH=sql_router.db

# Global SQL Server Credentials
# These are the master credentials used to connect to the SQL Server instance.
# The user will only select the specific database and tables via the frontend.
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=YourStrongPassword123

# Security
API_KEY_HEADER=x-api-key
